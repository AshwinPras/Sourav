   <div class="flex justify-between items-start mb-4">
    <h2 id="info-title" class="text-xl font-bold glow-text" style="font-family: 'Orbitron', sans-serif; color: #64d2ff;">Earth</h2><button id="close-info" class="text-xl opacity-60 hover:opacity-100 transition-opacity" style="color: #64d2ff;">×</button>
