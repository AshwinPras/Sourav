  <div id="tooltip" class="tooltip" style="color: #64d2ff;"></div>
  <script>
    // Configuration
    const defaultConfig = {
      main_title: 'Solar System Explorer',
      subtitle: 'Interactive 3D Space Navigation',
      background_color: '#0a0a1a',
      accent_color: '#64d2ff',
      text_color: '#a0c4ff',
      panel_color: '#0a1428',
      highlight_color: '#00aaff',
      font_family: 'Orbitron'
    };

    let config = { ...defaultConfig };

    // Celestial body data (real data, scaled for visualization)
    const celestialData = {
      sun: {
        name: 'The Sun',
        type: 'Star',
        diameter: '1,392,700 km',
        mass: '1.989 × 10³⁰ kg',
        temperature: '5,500°C (surface)',
        age: '4.6 billion years',
        composition: '73% Hydrogen, 25% Helium',
        facts: [
          'Contains 99.86% of the Solar System\'s mass',
          'Light takes 8 minutes to reach Earth',
          'Could fit 1.3 million Earths inside'
        ],
        color: '#ffaa00'
      },
      earth: {
        name: 'Earth',
        type: 'Terrestrial Planet',
        diameter: '12,742 km',
        mass: '5.972 × 10²⁴ kg',
        distanceFromSun: '149.6 million km (1 AU)',
        orbitalPeriod: '365.25 days',
        orbitalSpeed: '107,000 km/h',
        moons: 1,
        facts: [
          'Only planet known to harbor life',
          'Tilted 23.5° creating seasons',
          'Has a magnetic field protecting from solar radiation'
        ],
        color: '#4169E1'
      },
      moon: {
        name: 'The Moon',
        type: 'Natural Satellite',
        diameter: '3,474 km',
        mass: '7.342 × 10²² kg',
        distanceFromEarth: '384,400 km',
        orbitalPeriod: '27.3 days',
        orbitalSpeed: '3,683 km/h',
        facts: [
          'Tidally locked - same face always toward Earth',
          'Formed 4.5 billion years ago from a giant impact',
          'Causes Earth\'s tides through gravitational pull'
        ],
        color: '#c0c0c0'
      },
      mars: {
        name: 'Mars',
        type: 'Terrestrial Planet',
        diameter: '6,779 km',
        mass: '6.39 × 10²³ kg',
        distanceFromSun: '227.9 million km (1.52 AU)',
        orbitalPeriod: '687 days',
        orbitalSpeed: '86,677 km/h',
        moons: 2,
        facts: [
          'Called the Red Planet due to iron oxide',
          'Has the largest volcano in the Solar System (Olympus Mons)',
          'A day on Mars (sol) is 24h 37min'
        ],
        color: '#cc4400'
      }
    };

    // Educational facts
    const educationalFacts = [
      'Earth completes one orbit in 365.25 days, traveling at ~107,000 km/h.',
      'The Moon is slowly moving away from Earth at 3.8 cm per year.',
      'Mars appears red because of iron oxide (rust) on its surface.',
      'The Sun\'s gravity is 28 times stronger than Earth\'s.',
      'Light from the Sun takes about 12 minutes to reach Mars.',
      'Earth\'s orbit is slightly elliptical, varying by 5 million km.',
      'The Moon\'s gravity causes ocean tides on Earth.',
      'One year on Mars equals 687 Earth days.'
    ];

    // State
    let state = {
      timeSpeed: 1,
      zoom: 1,
      paused: false,
      showLabels: true,
      showOrbits: true,
      showDistances: false,
      selectedBody: null,
      earthAngle: 0,
      marsAngle: Math.PI * 0.7,
      moonAngle: 0,
      panX: 0,
      panY: 0,
      isDragging: false,
      lastX: 0,
      lastY: 0,
      factIndex: 0
    };

    // DOM Elements
    const solarSystem = document.getElementById('solar-system');
    const sun = document.getElementById('sun');
    const earth = document.getElementById('earth');
    const moon = document.getElementById('moon');
    const mars = document.getElementById('mars');
    const earthOrbit = document.getElementById('earth-orbit');
    const marsOrbit = document.getElementById('mars-orbit');
    const moonOrbit = document.getElementById('moon-orbit');
    const infoPanel = document.getElementById('info-panel');
    const tooltip = document.getElementById('tooltip');
    const distanceLines = document.getElementById('distance-lines');

    // Orbital parameters (scaled for display)
    const orbits = {
      earth: { radius: 180, speed: 0.001 },
      mars: { radius: 280, speed: 0.00053 },
      moon: { radius: 40, speed: 0.013 }
    };

    // Initialize positions
    function initializeScene() {
      const centerX = window.innerWidth / 2;
      const centerY = window.innerHeight / 2;

      // Position Sun at center
      sun.style.left = `${centerX - 60}px`;
      sun.style.top = `${centerY - 60}px`;

      // Setup orbit paths
      earthOrbit.style.width = `${orbits.earth.radius * 2}px`;
      earthOrbit.style.height = `${orbits.earth.radius * 2}px`;
      earthOrbit.style.left = `${centerX - orbits.earth.radius}px`;
      earthOrbit.style.top = `${centerY - orbits.earth.radius}px`;

      marsOrbit.style.width = `${orbits.mars.radius * 2}px`;
      marsOrbit.style.height = `${orbits.mars.radius * 2}px`;
      marsOrbit.style.left = `${centerX - orbits.mars.radius}px`;
      marsOrbit.style.top = `${centerY - orbits.mars.radius}px`;

      updatePositions();
    }

    // Update planet positions
    function updatePositions() {
      const centerX = window.innerWidth / 2 + state.panX;
      const centerY = window.innerHeight / 2 + state.panY;
      const zoom = state.zoom;

      // Update Sun position
      sun.style.left = `${centerX - 60 * zoom}px`;
      sun.style.top = `${centerY - 60 * zoom}px`;
      sun.style.transform = `scale(${zoom})`;

      // Update orbit paths
      earthOrbit.style.width = `${orbits.earth.radius * 2 * zoom}px`;
      earthOrbit.style.height = `${orbits.earth.radius * 2 * zoom}px`;
      earthOrbit.style.left = `${centerX - orbits.earth.radius * zoom}px`;
      earthOrbit.style.top = `${centerY - orbits.earth.radius * zoom}px`;
      earthOrbit.style.display = state.showOrbits ? 'block' : 'none';

      marsOrbit.style.width = `${orbits.mars.radius * 2 * zoom}px`;
      marsOrbit.style.height = `${orbits.mars.radius * 2 * zoom}px`;
      marsOrbit.style.left = `${centerX - orbits.mars.radius * zoom}px`;
      marsOrbit.style.top = `${centerY - orbits.mars.radius * zoom}px`;
      marsOrbit.style.display = state.showOrbits ? 'block' : 'none';

      // Calculate Earth position
      const earthX = centerX + Math.cos(state.earthAngle) * orbits.earth.radius * zoom - 25 * zoom;
      const earthY = centerY + Math.sin(state.earthAngle) * orbits.earth.radius * zoom - 25 * zoom;
      earth.style.left = `${earthX}px`;
      earth.style.top = `${earthY}px`;
      earth.style.transform = `scale(${zoom})`;

      // Calculate Moon position (orbits Earth)
      const earthCenterX = earthX + 25 * zoom;
      const earthCenterY = earthY + 25 * zoom;
      const moonX = earthCenterX + Math.cos(state.moonAngle) * orbits.moon.radius * zoom - 8 * zoom;
      const moonY = earthCenterY + Math.sin(state.moonAngle) * orbits.moon.radius * zoom - 8 * zoom;
      moon.style.left = `${moonX}px`;
      moon.style.top = `${moonY}px`;
      moon.style.transform = `scale(${zoom})`;

      // Moon orbit path (around Earth)
      moonOrbit.style.width = `${orbits.moon.radius * 2 * zoom}px`;
      moonOrbit.style.height = `${orbits.moon.radius * 2 * zoom}px`;
      moonOrbit.style.left = `${earthCenterX - orbits.moon.radius * zoom}px`;
      moonOrbit.style.top = `${earthCenterY - orbits.moon.radius * zoom}px`;
      moonOrbit.style.display = state.showOrbits ? 'block' : 'none';

      // Calculate Mars position
      const marsX = centerX + Math.cos(state.marsAngle) * orbits.mars.radius * zoom - 17.5 * zoom;
      const marsY = centerY + Math.sin(state.marsAngle) * orbits.mars.radius * zoom - 17.5 * zoom;
      mars.style.left = `${marsX}px`;
      mars.style.top = `${marsY}px`;
      mars.style.transform = `scale(${zoom})`;

      // Update labels visibility
      document.querySelectorAll('.planet-label').forEach(label => {
        label.style.display = state.showLabels ? 'block' : 'none';
      });

      // Update distance lines
      if (state.showDistances) {
        updateDistanceLines(centerX, centerY, earthCenterX, earthCenterY, 
                           marsX + 17.5 * zoom, marsY + 17.5 * zoom,
                           moonX + 8 * zoom, moonY + 8 * zoom);
      } else {
        distanceLines.innerHTML = '';
      }
    }

    // Update distance measurement lines
    function updateDistanceLines(sunX, sunY, earthX, earthY, marsX, marsY, moonX, moonY) {
      distanceLines.innerHTML = '';

      // Sun to Earth line
      createDistanceLine(sunX, sunY, earthX, earthY, '1 AU (149.6M km)', '#64d2ff');
      
      // Sun to Mars line
      createDistanceLine(sunX, sunY, marsX, marsY, '1.52 AU (227.9M km)', '#ff6644');
      
      // Earth to Moon line
      createDistanceLine(earthX, earthY, moonX, moonY, '384,400 km', '#aaaaaa');
    }

    function createDistanceLine(x1, y1, x2, y2, label, color) {
      const dx = x2 - x1;
      const dy = y2 - y1;
      const distance = Math.sqrt(dx * dx + dy * dy);
      const angle = Math.atan2(dy, dx);

      const line = document.createElement('div');
      line.className = 'distance-line';
      line.style.left = `${x1}px`;
      line.style.top = `${y1}px`;
      line.style.width = `${distance}px`;
      line.style.transform = `rotate(${angle}rad)`;
      line.style.background = `linear-gradient(90deg, ${color}, transparent)`;
      distanceLines.appendChild(line);

      const labelEl = document.createElement('div');
      labelEl.className = 'measurement-label';
      labelEl.style.left = `${(x1 + x2) / 2 - 40}px`;
      labelEl.style.top = `${(y1 + y2) / 2 - 10}px`;
      labelEl.textContent = label;
      labelEl.style.color = color;
      labelEl.style.borderColor = color;
      distanceLines.appendChild(labelEl);
    }

    // Animation loop
    function animate() {
      if (!state.paused) {
        state.earthAngle += orbits.earth.speed * state.timeSpeed;
        state.marsAngle += orbits.mars.speed * state.timeSpeed;
        state.moonAngle += orbits.moon.speed * state.timeSpeed;
      }
      updatePositions();
      requestAnimationFrame(animate);
    }

    // Show info panel
    function showInfo(bodyId) {
      const data = celestialData[bodyId];
      if (!data) return;

      state.selectedBody = bodyId;
      
      const infoTitle = document.getElementById('info-title');
      const infoContent = document.getElementById('info-content');
      
      infoTitle.textContent = data.name;
      
      let html = `
        <div class="text-xs space-y-3" style="color: ${config.text_color};">
          <div class="flex justify-between items-center pb-2 border-b border-white/10">
            <span class="opacity-70">Type</span>
            <span class="font-medium" style="color: ${config.accent_color};">${data.type}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="opacity-70">Diameter</span>
            <span>${data.diameter}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="opacity-70">Mass</span>
            <span>${data.mass}</span>
          </div>
      `;
      
      if (data.distanceFromSun) {
        html += `
          <div class="flex justify-between items-center">
            <span class="opacity-70">Distance from Sun</span>
            <span>${data.distanceFromSun}</span>
          </div>
        `;
      }
      
      if (data.distanceFromEarth) {
        html += `
          <div class="flex justify-between items-center">
            <span class="opacity-70">Distance from Earth</span>
            <span>${data.distanceFromEarth}</span>
          </div>
        `;
      }
      
      if (data.orbitalPeriod) {
        html += `
          <div class="flex justify-between items-center">
            <span class="opacity-70">Orbital Period</span>
            <span>${data.orbitalPeriod}</span>
          </div>
        `;
      }
      
      if (data.orbitalSpeed) {
        html += `
          <div class="flex justify-between items-center">
            <span class="opacity-70">Orbital Speed</span>
            <span>${data.orbitalSpeed}</span>
          </div>
        `;
      }
      
      if (data.temperature) {
        html += `
          <div class="flex justify-between items-center">
            <span class="opacity-70">Temperature</span>
            <span>${data.temperature}</span>
          </div>
        `;
      }
      
      html += `
        <div class="pt-3 border-t border-white/10">
          <p class="font-medium mb-2" style="color: ${config.accent_color};">Did You Know?</p>
          <ul class="space-y-1.5">
            ${data.facts.map(fact => `<li class="flex gap-2"><span style="color: ${config.accent_color};">•</span><span>${fact}</span></li>`).join('')}
          </ul>
        </div>
      </div>
      `;
      
      infoContent.innerHTML = html;
      infoPanel.classList.remove('hidden');
    }

    // Event Listeners
    document.querySelectorAll('.planet').forEach(planet => {
      planet.addEventListener('click', (e) => {
        e.stopPropagation();
        showInfo(planet.dataset.body);
      });
      
      planet.addEventListener('mouseenter', (e) => {
        const data = celestialData[planet.dataset.body];
        if (data) {
          tooltip.textContent = data.name;
          tooltip.style.opacity = '1';
          tooltip.style.left = `${e.clientX + 15}px`;
          tooltip.style.top = `${e.clientY + 15}px`;
        }
      });
      
      planet.addEventListener('mousemove', (e) => {
        tooltip.style.left = `${e.clientX + 15}px`;
        tooltip.style.top = `${e.clientY + 15}px`;
      });
      
      planet.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });
    });

    document.getElementById('close-info').addEventListener('click', () => {
      infoPanel.classList.add('hidden');
      state.selectedBody = null;
    });

    // Speed controls
    document.getElementById('speed-down').addEventListener('click', () => {
      state.timeSpeed = Math.max(0.25, state.timeSpeed / 2);
      document.getElementById('speed-display').textContent = `${state.timeSpeed}x`;
    });

    document.getElementById('speed-up').addEventListener('click', () => {
      state.timeSpeed = Math.min(16, state.timeSpeed * 2);
      document.getElementById('speed-display').textContent = `${state.timeSpeed}x`;
    });

    // Zoom control
    document.getElementById('zoom-slider').addEventListener('input', (e) => {
      state.zoom = parseFloat(e.target.value);
      updatePositions();
    });

    // Pause/Reset
    document.getElementById('pause-btn').addEventListener('click', () => {
      state.paused = !state.paused;
      document.getElementById('pause-btn').textContent = state.paused ? '▶️ Play' : '⏸️ Pause';
    });

    document.getElementById('reset-btn').addEventListener('click', () => {
      state.earthAngle = 0;
      state.marsAngle = Math.PI * 0.7;
      state.moonAngle = 0;
      state.timeSpeed = 1;
      state.zoom = 1;
      state.panX = 0;
      state.panY = 0;
      document.getElementById('speed-display').textContent = '1x';
      document.getElementById('zoom-slider').value = 1;
      updatePositions();
    });

    // Toggle buttons
    document.getElementById('toggle-labels').addEventListener('click', (e) => {
      state.showLabels = !state.showLabels;
      e.target.classList.toggle('active');
      updatePositions();
    });

    document.getElementById('toggle-orbits').addEventListener('click', (e) => {
      state.showOrbits = !state.showOrbits;
      e.target.classList.toggle('active');
      updatePositions();
    });

    document.getElementById('toggle-distances').addEventListener('click', (e) => {
      state.showDistances = !state.showDistances;
      e.target.classList.toggle('active');
      updatePositions();
    });

    // Pan with mouse drag
    solarSystem.addEventListener('mousedown', (e) => {
      if (e.target === solarSystem || e.target.classList.contains('stars')) {
        state.isDragging = true;
        state.lastX = e.clientX;
        state.lastY = e.clientY;
        solarSystem.style.cursor = 'grabbing';
      }
    });

    document.addEventListener('mousemove', (e) => {
      if (state.isDragging) {
        state.panX += e.clientX - state.lastX;
        state.panY += e.clientY - state.lastY;
        state.lastX = e.clientX;
        state.lastY = e.clientY;
        updatePositions();
      }
    });

    document.addEventListener('mouseup', () => {
      state.isDragging = false;
      solarSystem.style.cursor = 'default';
    });

    // Zoom with scroll
    solarSystem.addEventListener('wheel', (e) => {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      state.zoom = Math.max(0.3, Math.min(2, state.zoom * delta));
      document.getElementById('zoom-slider').value = state.zoom;
      updatePositions();
    });

    // Rotate educational facts
    setInterval(() => {
      state.factIndex = (state.factIndex + 1) % educationalFacts.length;
      document.getElementById('current-fact').textContent = educationalFacts[state.factIndex];
    }, 8000);

    // Window resize handler
    window.addEventListener('resize', updatePositions);

    // Element SDK Integration
    function onConfigChange(newConfig) {
      document.getElementById('main-title').textContent = newConfig.main_title || defaultConfig.main_title;
      document.getElementById('subtitle').textContent = newConfig.subtitle || defaultConfig.subtitle;
    }

    function mapToCapabilities(cfg) {
      return {
        recolorables: [
          {
            get: () => cfg.background_color || defaultConfig.background_color,
            set: (v) => { cfg.background_color = v; window.elementSdk.setConfig({ background_color: v }); }
          },
          {
            get: () => cfg.panel_color || defaultConfig.panel_color,
            set: (v) => { cfg.panel_color = v; window.elementSdk.setConfig({ panel_color: v }); }
          },
          {
            get: () => cfg.accent_color || defaultConfig.accent_color,
            set: (v) => { cfg.accent_color = v; window.elementSdk.setConfig({ accent_color: v }); }
          },
          {
            get: () => cfg.text_color || defaultConfig.text_color,
            set: (v) => { cfg.text_color = v; window.elementSdk.setConfig({ text_color: v }); }
          },
          {
            get: () => cfg.highlight_color || defaultConfig.highlight_color,
            set: (v) => { cfg.highlight_color = v; window.elementSdk.setConfig({ highlight_color: v }); }
          }
        ],
        borderables: [],
        fontEditable: {
          get: () => cfg.font_family || defaultConfig.font_family,
          set: (v) => { cfg.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
        },
        fontSizeable: undefined
      };
    }

    function mapToEditPanelValues(cfg) {
      return new Map([
        ['main_title', cfg.main_title || defaultConfig.main_title],
        ['subtitle', cfg.subtitle || defaultConfig.subtitle]
      ]);
    }

    // Initialize
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange,
        mapToCapabilities,
        mapToEditPanelValues
      });
    }

    initializeScene();
    animate();
  </script>
